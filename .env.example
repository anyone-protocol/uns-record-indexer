PORT=3000

# Base chain
BASE_CHAIN_ID=8453
START_BLOCK=0
BLOCK_CONFIRMATIONS=12
# Primary RPC provider (Infura)
INFURA_HTTP_RPC_URL=
INFURA_WS_RPC_URL=
# Backup RPC provider (Alchemy) - leave empty to disable failover
ALCHEMY_HTTP_RPC_URL=
ALCHEMY_WS_RPC_URL=
UNS_CONTRACT_ADDRESS=

# RPC failover
# How long to stay on the backup provider before trying the primary again (ms)
RPC_FAILOVER_COOLDOWN_MS=600000
# Set to false to never auto-heal-back to the primary after a failover
RPC_FAILOVER_HEAL_BACK_ENABLED=true
# Consecutive soft errors (5xx/timeout) before rotating providers
RPC_FAILOVER_ERROR_THRESHOLD=3

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uns_indexer

# Read-only DB user (provisioned / synced by migrate.js on every run)
# Leave empty to skip provisioning. When set, the role is created (or its
# password rotated) and granted SELECT on all current and future tables in
# the public schema.
DB_READ_USER=
DB_READ_PASSWORD=

# Indexing semantics
WATCHED_UNS_KEY=token.ANYONE.ANYONE.ANYONE.address
REQUIRED_VALUE_SUFFIX=.anyone

# Healing
# Delay in ms between end of one healing cycle and start of the next (default 5 min)
HEALING_INTERVAL_MS=3600000
HEALING_BLOCK_CHUNK_SIZE=10000
# Delay in ms between consecutive getLogs chunk requests (avoids rate limiting)
HEALING_CHUNK_DELAY_MS=1000

# UNS token (ERC-721 Transfer) healing — tracks current owner + domain name
# of every .anyone UNS token. Each var falls back to its HEALING_* / START_BLOCK
# equivalent when empty, so leaving these blank keeps both pipelines aligned.
UNS_TOKEN_START_BLOCK=
UNS_TOKEN_HEALING_INTERVAL_MS=86400000
UNS_TOKEN_HEALING_BLOCK_CHUNK_SIZE=10000
UNS_TOKEN_HEALING_CHUNK_DELAY_MS=1000

# Unstoppable Domains metadata API
# In-flight retries when resolving a token's domain name during Set event processing
METADATA_FETCH_MAX_ATTEMPTS=4
METADATA_FETCH_BASE_DELAY_MS=500
METADATA_FETCH_TIMEOUT_MS=5000
# Background backfill of records whose name resolution previously failed
METADATA_BACKFILL_INTERVAL_MS=600000
METADATA_BACKFILL_BATCH_SIZE=25
METADATA_BACKFILL_REQUEST_DELAY_MS=200

# Background backfill of UNS tokens whose metadata couldn't be resolved when
# their Transfer event was first processed. Each var falls back to its
# METADATA_BACKFILL_* equivalent when empty.
UNS_TOKEN_BACKFILL_INTERVAL_MS=
UNS_TOKEN_BACKFILL_BATCH_SIZE=
UNS_TOKEN_BACKFILL_REQUEST_DELAY_MS=
