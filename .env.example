PORT=3000

# Base chain
BASE_CHAIN_ID=8453
START_BLOCK=0
BLOCK_CONFIRMATIONS=12
INFURA_HTTP_RPC_URL=
INFURA_WS_RPC_URL=
UNS_CONTRACT_ADDRESS=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uns_indexer

# Indexing semantics
WATCHED_UNS_KEY=token.ANYONE.ANYONE.ANYONE.address
REQUIRED_VALUE_SUFFIX=.anyone

# Healing
# Delay in ms between end of one healing cycle and start of the next (default 5 min)
HEALING_INTERVAL_MS=300000
HEALING_BLOCK_CHUNK_SIZE=2000
# Delay in ms between consecutive getLogs chunk requests (avoids rate limiting)
HEALING_CHUNK_DELAY_MS=250
